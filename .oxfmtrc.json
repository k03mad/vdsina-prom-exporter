{
  "": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["node_modules/**"],
  "singleQuote": true,
  "arrowParens": "avoid",
  "bracketSpacing": false,
  "quoteProps": "consistent",
  "sortImports": {
    "groups": [
      ["builtin"],
      ["external", "type-external"],
      ["internal", "type-internal"],
      ["parent", "type-parent"],
      ["sibling", "type-sibling"],
      ["index", "type-index"]
    ]
  },
  "tabWidth": 2,
  "trailingComma": "none",
  "overrides": [
    {
      "files": ["*.js", "*.ts"],
      "options": {
        "tabWidth": 4,
        "trailingComma": "all"
      }
    }
  ]
}
